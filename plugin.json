{
  "name": "focus",
  "version": "0.1.0",
  "description": "Kanban card manager for personal task tracking",
  "coda": ">=0.1.0",
  "dependencies": {
    "system": ["focus"]
  },
  "provides": {
    "commands": {
      "focus": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus"
      },
      "focus-new": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_new"
      },
      "focus-show": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_show"
      },
      "focus-activate": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_activate"
      },
      "focus-done": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_done"
      },
      "focus-park": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_park"
      },
      "focus-kill": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_kill"
      },
      "focus-edit": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_edit"
      },
      "focus-list": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_list"
      },
      "focus-intent": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_intent"
      },
      "focus-milestone-new": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_milestone_new"
      },
      "focus-milestone-show": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_milestone_show"
      },
      "focus-milestone-list": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_milestone_list"
      },
      "focus-milestone-add": {
        "handler": "coda-handler.sh",
        "function": "_coda_focus_milestone_add"
      }
    },
    "completions": {
      "focus": {
        "subcommands": "board new milestone show activate park kill done edit intent wip list tui init setup help"
      }
    },
    "hooks": {
      "post-feature-create": ["hooks/post-feature-create/*"],
      "pre-feature-teardown": ["hooks/pre-feature-teardown/*"]
    },
    "mcp_tools": {
      "coda_focus_board": {
        "description": "Show the focus kanban board (active + backlog cards)",
        "command": ["focus", "board", "--no-color"]
      },
      "coda_focus_new": {
        "description": "Create a new backlog card on the focus kanban board",
        "command": ["focus-new"],
        "params": {
          "title": {
            "type": "string",
            "description": "Card title"
          },
          "project": {
            "type": "string",
            "description": "Project name for the card",
            "optional": true
          }
        }
      },
      "coda_focus_show": {
        "description": "Show details of a focus kanban card",
        "command": ["focus-show"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          }
        }
      },
      "coda_focus_activate": {
        "description": "Move a focus kanban card to active status",
        "command": ["focus-activate"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          },
          "force": {
            "type": "boolean",
            "description": "Bypass WIP limit",
            "optional": true
          }
        }
      },
      "coda_focus_done": {
        "description": "Mark a focus kanban card as done",
        "command": ["focus-done"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          },
          "force": {
            "type": "boolean",
            "description": "Bypass completion contract checks",
            "optional": true
          }
        }
      },
      "coda_focus_park": {
        "description": "Park a focus kanban card (move to parked status)",
        "command": ["focus-park"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          }
        }
      },
      "coda_focus_kill": {
        "description": "Kill a focus kanban card (move to killed status)",
        "command": ["focus-kill"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          }
        }
      },
      "coda_focus_edit": {
        "description": "Open a focus kanban card in the editor. Returns the card file path for agent use.",
        "command": ["focus-edit"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Card ID or slug"
          }
        }
      },
      "coda_focus_list": {
        "description": "List focus kanban cards, optionally filtered by status",
        "command": ["focus-list"],
        "params": {
          "status": {
            "type": "string",
            "description": "Filter by status: active, backlog, done, parked, killed",
            "optional": true
          },
          "project": {
            "type": "string",
            "description": "Filter by project name",
            "optional": true
          }
        }
      },
      "coda_focus_wip": {
        "description": "Show focus WIP (work in progress) status and active card count",
        "command": ["focus", "wip", "--no-color"]
      },
      "coda_focus_intent": {
        "description": "Set or show the current session intent for focus",
        "command": ["focus-intent"],
        "params": {
          "message": {
            "type": "string",
            "description": "Intent message to set (omit to show current intent)",
            "optional": true
          }
        }
      },
      "coda_focus_milestone_new": {
        "description": "Create a new milestone card on the focus kanban board",
        "command": ["focus-milestone-new"],
        "params": {
          "title": {
            "type": "string",
            "description": "Milestone title"
          },
          "project": {
            "type": "string",
            "description": "Project name for the milestone (use 'cross-project' when children span projects)",
            "optional": true
          }
        }
      },
      "coda_focus_milestone_show": {
        "description": "Show a focus milestone with progress and children (by status)",
        "command": ["focus-milestone-show"],
        "params": {
          "ref": {
            "type": "string",
            "description": "Milestone card ID or slug"
          }
        }
      },
      "coda_focus_milestone_list": {
        "description": "List all focus milestones with progress summaries",
        "command": ["focus", "milestone", "list", "--no-color"]
      },
      "coda_focus_milestone_add": {
        "description": "Link a focus card to a milestone by setting its milestone field",
        "command": ["focus-milestone-add"],
        "params": {
          "milestone": {
            "type": "string",
            "description": "Milestone card ID or slug"
          },
          "card": {
            "type": "string",
            "description": "Child card ID or slug"
          }
        }
      }
    }
  }
}
