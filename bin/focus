#!/usr/bin/env bash
# focus — kanban card manager for personal task tracking
#
# All card state lives as markdown files with YAML frontmatter.
# This script is the ONLY interface for state transitions. Never hand-edit status fields.
#
# Usage:  focus <command> [args]
# Run:    focus help

set -euo pipefail

FOCUS_VERSION="0.1.0"

# ── Configuration ────────────────────────────────────────────

FOCUS_HOME="${FOCUS_HOME:-$HOME/.focus}"
FOCUS_CONFIG_FILE="$FOCUS_HOME/config"

_focus_read_config() {
  local key="$1"
  [[ -f "$FOCUS_CONFIG_FILE" ]] || return 1
  sed -n "s/^${key}:[[:space:]]*//p" "$FOCUS_CONFIG_FILE" | head -1
}

_focus_write_config() {
  local key="$1" value="$2"
  mkdir -p "$FOCUS_HOME"
  if [[ -f "$FOCUS_CONFIG_FILE" ]] && grep -q "^${key}:" "$FOCUS_CONFIG_FILE"; then
    sed -i "s|^${key}:.*|${key}: ${value}|" "$FOCUS_CONFIG_FILE"
  elif [[ -f "$FOCUS_CONFIG_FILE" ]]; then
    printf '%s: %s\n' "$key" "$value" >> "$FOCUS_CONFIG_FILE"
  else
    printf '%s: %s\n' "$key" "$value" > "$FOCUS_CONFIG_FILE"
  fi
}

FOCUS_KANBAN_DIR="${FOCUS_KANBAN_DIR:-$(_focus_read_config kanban_dir || true)}"
FOCUS_KANBAN_DIR="${FOCUS_KANBAN_DIR:-$FOCUS_HOME/kanban}"

FOCUS_WIP_LIMIT="${FOCUS_WIP_LIMIT:-$(_focus_read_config wip_limit || true)}"
FOCUS_WIP_LIMIT="${FOCUS_WIP_LIMIT:-3}"

FOCUS_INTENT_DIR="${FOCUS_INTENT_DIR:-$FOCUS_HOME/intents}"
FORCE=false
QUIET=false
COLOR_ENABLED=true
FILTER_PROJECT=""
FILTER_PRIORITY=""

_focus_require_kanban_dir() {
  if [[ ! -d "$FOCUS_KANBAN_DIR" ]]; then
    echo "error: kanban directory not found: $FOCUS_KANBAN_DIR" >&2
    echo "" >&2
    echo "Run one of:" >&2
    echo "  focus init              Create the default board at ~/.focus/kanban" >&2
    echo "  focus setup <path>      Point focus at an existing kanban directory" >&2
    exit 1
  fi
}

# ── Helpers ──────────────────────────────────────────────────

_focus_slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//'
}

_focus_today() {
  date +%Y-%m-%d
}

_focus_priority_rank() {
  case "${1:-}" in
    p0) echo 0 ;;
    p1) echo 1 ;;
    p2) echo 2 ;;
    p3) echo 3 ;;
    *)  echo 9 ;;
  esac
}

_focus_status_order() {
  case "${1:-}" in
    active)  echo 0 ;;
    backlog) echo 1 ;;
    done)    echo 2 ;;
    parked)  echo 3 ;;
    killed)  echo 4 ;;
    *)       echo 9 ;;
  esac
}

_focus_truncate() {
  local text="${1:-}" max="${2:-40}"
  if (( ${#text} <= max )); then
    printf "%s" "$text"
  elif (( max > 3 )); then
    printf "%s..." "${text:0:$((max - 3))}"
  else
    printf "%s" "${text:0:$max}"
  fi
}

_color() {
  local code="$1" text="$2"
  if ! $COLOR_ENABLED || [[ -n "${NO_COLOR:-}" ]]; then
    printf "%s" "$text"
  else
    printf "\033[%sm%s\033[0m" "$code" "$text"
  fi
}

_focus_status_display() {
  local status="$1"
  case "$status" in
    active)  _color "32;1" "$status" ;;
    backlog) _color "36" "$status" ;;
    done)    _color "90" "$status" ;;
    parked)  _color "33" "$status" ;;
    killed)  _color "31" "$status" ;;
    *)       printf "%s" "$status" ;;
  esac
}

_focus_priority_display() {
  local priority="$1"
  case "$priority" in
    p0) _color "31;1" "$priority" ;;
    p1) _color "33;1" "$priority" ;;
    p2) _color "36" "$priority" ;;
    p3) _color "90" "$priority" ;;
    *)  printf "%s" "$priority" ;;
  esac
}

_focus_read_field() {
  local file="$1" field="$2"
  sed -n '/^---$/,/^---$/p' "$file" | grep "^${field}:" | head -1 | sed "s/^${field}:[[:space:]]*//" || true
}

_focus_read_body() {
  local file="$1"
  awk 'BEGIN { sep = 0 } /^---$/ { sep++; next } sep >= 2 { print }' "$file"
}

_focus_read_contract_items() {
  local file="$1"
  local in_contract=false
  while IFS= read -r line; do
    if [[ "$line" =~ ^contract: ]]; then
      in_contract=true
      continue
    fi
    if $in_contract; then
      if [[ "$line" =~ ^[[:space:]]+-[[:space:]](.+) ]]; then
        printf "%s\n" "${BASH_REMATCH[1]}"
      else
        break
      fi
    fi
  done < "$file"
}

_focus_set_field() {
  local file="$1" field="$2" value="$3"

  if grep -q "^${field}:" <(sed -n '/^---$/,/^---$/p' "$file"); then
    sed -i "s|^${field}:.*|${field}: ${value}|" "$file"
  else
    local line
    line=$(grep -n "^---$" "$file" | tail -1 | cut -d: -f1)
    sed -i "${line}i\\${field}: ${value}" "$file"
  fi
}

_focus_card_files() {
  local status_filter="${1:-}"
  if [[ -z "$status_filter" ]]; then
    find "$FOCUS_KANBAN_DIR" -maxdepth 1 -name '*.md' -type f 2>/dev/null | sort
  else
    for f in "$FOCUS_KANBAN_DIR"/*.md; do
      [[ -f "$f" ]] || continue
      local s
      s="$(_focus_read_field "$f" "status")"
      if [[ "$s" == "$status_filter" ]]; then
        echo "$f"
      fi
    done
  fi
}

_focus_find_by_id() {
  local id="$1"
  local f card_id
  for f in "$FOCUS_KANBAN_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    card_id="$(_focus_read_field "$f" "id")"
    if [[ "$card_id" == "$id" ]]; then
      echo "$f"
      return 0
    fi
  done
  echo "error: card not found: $id" >&2
  echo "  hint: run 'focus list' to see available cards" >&2
  return 1
}

_focus_next_id() {
  local max_id=0
  local f card_id
  for f in "$FOCUS_KANBAN_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    card_id="$(_focus_read_field "$f" "id")"
    if [[ "$card_id" =~ ^[0-9]+$ ]] && (( card_id > max_id )); then
      max_id=$card_id
    fi
  done
  echo $((max_id + 1))
}

_focus_count_active() {
  local count=0
  for f in "$FOCUS_KANBAN_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    if [[ "$(_focus_read_field "$f" "status")" == "active" ]]; then
      ((++count))
    fi
  done
  echo "$count"
}

_focus_card_path() {
  local ref="$1"
  if [[ "$ref" =~ ^[0-9]+$ ]]; then
    _focus_find_by_id "$ref"
    return $?
  fi

  local path="$FOCUS_KANBAN_DIR/${ref}.md"
  if [[ ! -f "$path" ]]; then
    echo "error: card not found: $ref" >&2
    echo "  hint: run 'focus list' to see available cards" >&2
    return 1
  fi
  echo "$path"
}

_focus_card_ref() {
  local file="$1"
  local id
  id="$(_focus_read_field "$file" "id")"
  if [[ -n "$id" ]]; then
    printf "%s" "$id"
  else
    basename "$file" .md
  fi
}

_focus_matches_filters() {
  local file="$1"
  local project priority
  project="$(_focus_read_field "$file" "project")"
  priority="$(_focus_read_field "$file" "priority")"

  if [[ -n "$FILTER_PROJECT" ]] && [[ "$project" != "$FILTER_PROJECT" ]]; then
    return 1
  fi
  if [[ -n "$FILTER_PRIORITY" ]] && [[ "$priority" != "$FILTER_PRIORITY" ]]; then
    return 1
  fi
  return 0
}

_focus_sorted_files_for_status() {
  local status_filter="$1"
  local f priority updated id
  for f in "$FOCUS_KANBAN_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(_focus_read_field "$f" "status")" == "$status_filter" ]] || continue
    _focus_matches_filters "$f" || continue
    priority="$(_focus_read_field "$f" "priority")"
    updated="$(_focus_read_field "$f" "updated")"
    id="$(_focus_read_field "$f" "id")"
    printf '%s\t%s\t%s\t%s\n' "$(_focus_priority_rank "$priority")" "$updated" "${id:-999999}" "$f"
  done | sort -t $'\t' -k1,1n -k2,2r -k3,3n | while IFS=$'\t' read -r _ _ _ path; do
    [[ -n "$path" ]] && printf "%s\n" "$path"
  done
}

_focus_print_table_header() {
  printf "%-4s  %-40s  %-24s  %-8s  %-8s  %-10s\n" "ID" "Title" "Project" "Status" "Priority" "Updated"
}

_focus_print_table_row() {
  local file="$1"
  local id title status project priority updated
  id="$(_focus_card_ref "$file")"
  title="$(_focus_truncate "$(_focus_read_field "$file" "title")" 40)"
  project="$(_focus_truncate "$(_focus_read_field "$file" "project")" 24)"
  status="$(_focus_read_field "$file" "status")"
  priority="$(_focus_read_field "$file" "priority")"
  updated="$(_focus_read_field "$file" "updated")"

  printf "%-4s  %-40s  %-24s  " "$id" "$title" "$project"
  printf "%-8b  %-8b  %-10s\n" "$(_focus_status_display "$status")" "$(_focus_priority_display "$priority")" "$updated"
}

_focus_print_status_section() {
  local status="$1" label="$2"
  local files
  mapfile -t files < <(_focus_sorted_files_for_status "$status")

  echo "$label"
  echo "$(printf '%*s' ${#label} '' | tr ' ' '-')"
  _focus_print_table_header
  if (( ${#files[@]} == 0 )); then
    echo "(none)"
  else
    local f
    for f in "${files[@]}"; do
      _focus_print_table_row "$f"
    done
  fi
  echo ""
}

_focus_print_card_line() {
  _focus_print_table_row "$1"
}

_focus_contract_status() {
  local file="$1"
  local total=0 checked=0

  while IFS= read -r _; do
    ((++total))
  done < <(_focus_read_contract_items "$file")

  while IFS= read -r line; do
    if [[ "$line" =~ ^\-[[:space:]]\[x\] ]] || [[ "$line" =~ ^\-[[:space:]]\[X\] ]]; then
      ((++checked))
    fi
  done < <(_focus_read_body "$file")

  if [[ $total -eq 0 ]]; then
    echo "no contract"
  else
    echo "${checked}/${total}"
  fi
}

# ── Commands ─────────────────────────────────────────────────

_focus_cmd_board() {
  _focus_require_kanban_dir
  local active_count
  active_count="$(_focus_count_active)"

  echo "$(_color '35;1' 'Focus Board')"
  echo "==========="
  echo ""
  echo "WIP: ${active_count}/${FOCUS_WIP_LIMIT} slots"
  echo ""

  _focus_print_status_section "active" "$(_color '32;1' 'ACTIVE')"
  _focus_print_status_section "backlog" "$(_color '36' 'BACKLOG')"

  # Intent
  local session_name=""
  if [[ -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$session_name" ]] && [[ -f "$FOCUS_INTENT_DIR/${session_name}.txt" ]]; then
    echo "SESSION INTENT: $(cat "$FOCUS_INTENT_DIR/${session_name}.txt")"
  fi
}

_focus_cmd_new() {
  _focus_require_kanban_dir
  local title="${1:-}"
  local project="${2:-}"

  if [[ -z "$title" ]]; then
    echo "usage: focus new \"title\" [project]" >&2
    return 1
  fi

  local slug
  slug="$(_focus_slugify "$title")"
  local path="$FOCUS_KANBAN_DIR/${slug}.md"
  local id
  id="$(_focus_next_id)"

  if [[ -f "$path" ]]; then
    echo "error: card already exists: $slug" >&2
    echo "  hint: pick a different title or edit the existing card" >&2
    return 1
  fi

  local today
  today="$(_focus_today)"

  local project_line=""
  [[ -n "$project" ]] && project_line="project: ${project}"

  cat > "$path" << EOF
---
id: ${id}
title: ${title}
${project_line:+${project_line}
}status: backlog
priority: p2
created: ${today}
updated: ${today}
---

## Notes

EOF

  if ! $QUIET; then
    echo "Created: #${id} ${slug} (backlog)"
    echo "  Edit with: focus edit ${id}"
  fi
}

_focus_cmd_show() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus show <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1

  local id title project status priority created updated slug
  id="$(_focus_read_field "$path" "id")"
  title="$(_focus_read_field "$path" "title")"
  project="$(_focus_read_field "$path" "project")"
  status="$(_focus_read_field "$path" "status")"
  priority="$(_focus_read_field "$path" "priority")"
  created="$(_focus_read_field "$path" "created")"
  updated="$(_focus_read_field "$path" "updated")"
  slug="$(basename "$path" .md)"

  echo "Task"
  echo "----"
  echo "ID:       ${id}"
  echo "Title:    ${title}"
  echo "Project:  ${project}"
  echo "Status:   ${status}"
  echo "Priority: ${priority}"
  echo "Created:  ${created}"
  echo "Updated:  ${updated}"
  echo "Slug:     ${slug}"
  echo ""
  echo "Contract items:"
  local found_contract=false
  while IFS= read -r item; do
    found_contract=true
    echo "  - ${item}"
  done < <(_focus_read_contract_items "$path")
  $found_contract || echo "  (none)"
  echo ""
  echo "Body:"
  _focus_read_body "$path"
}

_focus_cmd_activate() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus activate <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1
  local card_ref
  card_ref="$(_focus_card_ref "$path")"

  local current_status
  current_status="$(_focus_read_field "$path" "status")"
  if [[ "$current_status" == "active" ]]; then
    echo "Card is already active: $card_ref" >&2
    return 0
  fi

  # WIP limit check
  local active_count
  active_count="$(_focus_count_active)"
  if [[ $active_count -ge $FOCUS_WIP_LIMIT ]] && ! $FORCE; then
    echo "WIP limit reached (${active_count}/${FOCUS_WIP_LIMIT})" >&2
    echo "" >&2
    echo "Active cards:" >&2
    for f in "$FOCUS_KANBAN_DIR"/*.md; do
      [[ -f "$f" ]] || continue
      if [[ "$(_focus_read_field "$f" "status")" == "active" ]]; then
        echo "  - $(_focus_read_field "$f" "title")" >&2
      fi
    done
    echo "" >&2
    echo "Park or finish something first, or use --force to override." >&2
    return 1
  fi

  _focus_set_field "$path" "status" "active"
  _focus_set_field "$path" "updated" "$(_focus_today)"

  if ! $QUIET; then
    active_count="$(_focus_count_active)"
    echo "Activated: $card_ref (WIP: ${active_count}/${FOCUS_WIP_LIMIT})"
  fi
}

_focus_cmd_park() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus park <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1

  _focus_set_field "$path" "status" "parked"
  _focus_set_field "$path" "updated" "$(_focus_today)"

  if ! $QUIET; then
    echo "Parked: $(_focus_card_ref "$path")"
  fi
}

_focus_cmd_kill() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus kill <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1

  _focus_set_field "$path" "status" "killed"
  _focus_set_field "$path" "updated" "$(_focus_today)"

  if ! $QUIET; then
    echo "Killed: $(_focus_card_ref "$path")"
  fi
}

_focus_cmd_done() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus done <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1
  local card_ref
  card_ref="$(_focus_card_ref "$path")"

  # Contract check
  local contract_items=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && contract_items+=("$line")
  done < <(_focus_read_contract_items "$path")

  if [[ ${#contract_items[@]} -gt 0 ]] && ! $FORCE; then
    echo "Completion contract for: $card_ref"
    echo ""
    local all_met=true
    for item in "${contract_items[@]}"; do
      read -p "  [?] ${item} (y/n): " answer < /dev/tty
      if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
        all_met=false
      fi
    done
    echo ""
    if ! $all_met; then
      read -p "Contract incomplete. Mark done anyway? (y/n): " confirm < /dev/tty
      if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Aborted. Card remains in current status."
        return 1
      fi
    fi
  fi

  _focus_set_field "$path" "status" "done"
  _focus_set_field "$path" "updated" "$(_focus_today)"

  if ! $QUIET; then
    echo "Done: $card_ref"
  fi
}

_focus_cmd_edit() {
  _focus_require_kanban_dir
  local ref="${1:-}"
  if [[ -z "$ref" ]]; then
    echo "usage: focus edit <id|slug>" >&2
    return 1
  fi

  local path
  path="$(_focus_card_path "$ref")" || return 1

  "${EDITOR:-vi}" "$path"

  _focus_set_field "$path" "updated" "$(_focus_today)"
}

_focus_cmd_intent() {
  local message="${1:-}"

  mkdir -p "$FOCUS_INTENT_DIR"

  local session_name="default"
  if [[ -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || echo "default")"
  fi

  local intent_file="$FOCUS_INTENT_DIR/${session_name}.txt"

  if [[ -z "$message" ]]; then
    if [[ -f "$intent_file" ]]; then
      echo "Session: $session_name"
      echo "Intent:  $(cat "$intent_file")"
    else
      echo "No intent set for session: $session_name"
      echo "  Set one: focus intent \"deploy voice-claude\""
    fi
    return 0
  fi

  echo "$message" > "$intent_file"

  if [[ -n "${TMUX:-}" ]]; then
    tmux set-environment SESSION_INTENT "$message" 2>/dev/null || true
  fi

  if ! $QUIET; then
    echo "Intent set: $message"
  fi
}

_focus_cmd_wip() {
  _focus_require_kanban_dir
  local active_count
  active_count="$(_focus_count_active)"

  echo "WIP: ${active_count}/${FOCUS_WIP_LIMIT}"
  echo ""

  if [[ $active_count -eq 0 ]]; then
    echo "No active cards. Pick something from the backlog:"
    echo ""
    _focus_cmd_list "backlog"
    return 0
  fi

  _focus_print_table_header
  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] && _focus_print_card_line "$f"
  done < <(_focus_sorted_files_for_status "active")
}

_focus_cmd_list() {
  _focus_require_kanban_dir
  local status_filter="${1:-}"

  if [[ -n "$status_filter" ]]; then
    echo "Cards (${status_filter}):"
    echo ""
    _focus_print_table_header
    local found=false
    local f
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      _focus_print_card_line "$f"
      found=true
    done < <(_focus_sorted_files_for_status "$status_filter")
    $found || echo "(none)"
  else
    echo "All cards:"
    echo ""
    _focus_print_status_section "active" "$(_color '32;1' 'ACTIVE')"
    _focus_print_status_section "backlog" "$(_color '36' 'BACKLOG')"
    _focus_print_status_section "done" "$(_color '90' 'DONE')"
    _focus_print_status_section "parked" "$(_color '33' 'PARKED')"
    _focus_print_status_section "killed" "$(_color '31' 'KILLED')"
  fi
}

_focus_cmd_init() {
  local target="${1:-$FOCUS_HOME/kanban}"

  if [[ -d "$target" ]]; then
    echo "Directory already exists: $target" >&2
    echo "  To use it: focus setup $target" >&2
    return 1
  fi

  mkdir -p "$target"

  local today
  today="$(_focus_today)"
  cat > "$target/getting-started.md" << EOF
---
id: 1
title: Getting started with focus
status: active
priority: p1
created: ${today}
updated: ${today}
contract:
  - Read through 'focus help'
  - Create a card with 'focus new'
  - Complete this card with 'focus done 1'
---

## Notes

Welcome to focus! This is a sample card to get you started.

Each card is a markdown file with YAML frontmatter tracking its state.
The \`focus\` command is the only interface for state transitions.

Try: \`focus board\` to see your board.
EOF

  _focus_write_config kanban_dir "$target"

  echo "Initialized kanban board: $target"
  echo "Created sample card: getting-started"
  echo ""
  echo "Try: focus board"
}

_focus_cmd_setup() {
  local kanban_dir="${1:-}"

  if [[ -z "$kanban_dir" ]]; then
    echo "usage: focus setup <path-to-kanban-dir>" >&2
    return 1
  fi

  if [[ ! -d "$kanban_dir" ]]; then
    echo "error: directory not found: $kanban_dir" >&2
    echo "  To create a new board, use: focus init" >&2
    return 1
  fi

  _focus_write_config kanban_dir "$kanban_dir"

  echo "Setup complete. focus will use: $kanban_dir"
  echo "Config saved to: $FOCUS_CONFIG_FILE"
}

_focus_cmd_completions() {
  local shell="${1:-bash}"
  case "$shell" in
    bash)
      cat << 'BASH_COMPLETION'
_focus_completion_kanban_dir() {
  local kanban_dir="${FOCUS_KANBAN_DIR:-}"
  if [[ -z "$kanban_dir" ]] && [[ -f "${FOCUS_HOME:-$HOME/.focus}/config" ]]; then
    kanban_dir=$(sed -n 's/^kanban_dir:[[:space:]]*//p' "${FOCUS_HOME:-$HOME/.focus}/config" | head -1)
  fi
  echo "${kanban_dir:-${FOCUS_HOME:-$HOME/.focus}/kanban}"
}

_focus_completion_read_field() {
  local file="$1" field="$2"
  sed -n '/^---$/,/^---$/p' "$file" | grep "^${field}:" | head -1 | sed "s/^${field}:[[:space:]]*//"
}

_focus_completion_truncate() {
  local text="$1" max="$2"
  if (( ${#text} <= max )); then
    printf '%s' "$text"
  elif (( max > 3 )); then
    printf '%s...' "${text:0:$((max - 3))}"
  else
    printf '%s' "${text:0:$max}"
  fi
}

_focus_complete_cards() {
  local cur="$1" cmd="$2"
  local kanban_dir
  kanban_dir="$(_focus_completion_kanban_dir)"
  [[ -n "$kanban_dir" ]] && [[ -d "$kanban_dir" ]] || return 0

  local ids=() descriptions=()
  local f id title project status priority
  for f in "$kanban_dir"/*.md; do
    [[ -f "$f" ]] || continue
    id="$(_focus_completion_read_field "$f" "id")"
    [[ -n "$id" ]] || continue
    status="$(_focus_completion_read_field "$f" "status")"

    case "$cmd" in
      activate) [[ "$status" == "backlog" ]] || continue ;;
      park)     [[ "$status" == "active" ]] || continue ;;
      done)     [[ "$status" == "active" ]] || continue ;;
      kill)     [[ "$status" == "backlog" || "$status" == "active" || "$status" == "parked" ]] || continue ;;
      show|edit) ;;
    esac

    title="$(_focus_completion_truncate "$(_focus_completion_read_field "$f" "title")" 40)"
    project="$(_focus_completion_truncate "$(_focus_completion_read_field "$f" "project")" 24)"
    priority="$(_focus_completion_read_field "$f" "priority")"
    ids+=("$id")
    descriptions+=("$(printf '%-4s  %-40s  %-24s  %-8s  %s' "$id" "$title" "${project:-}" "$status" "$priority")")
  done

  local sorted
  sorted=$(for i in "${!ids[@]}"; do printf '%s\t%s\n' "${ids[$i]}" "${descriptions[$i]}"; done | sort -t $'\t' -k1,1n)

  ids=() descriptions=()
  while IFS=$'\t' read -r id desc; do
    [[ -n "$id" ]] || continue
    ids+=("$id")
    descriptions+=("$desc")
  done <<< "$sorted"

  if [[ -n "$cur" ]]; then
    local id
    for id in "${ids[@]}"; do
      [[ "$id" == "$cur"* ]] && COMPREPLY+=("$id")
    done
  else
    COMPREPLY=("${ids[@]}")
  fi

  if (( ${#COMPREPLY[@]} > 1 )) || { (( ${#COMPREPLY[@]} == 1 )) && [[ -z "$cur" ]]; }; then
    printf '\n' >&2
    printf '%-4s  %-40s  %-24s  %-8s  %s\n' 'ID' 'Title' 'Project' 'Status' 'Priority' >&2
    local desc
    for desc in "${descriptions[@]}"; do
      printf '%s\n' "$desc" >&2
    done
    printf '\n' >&2
  fi
}

_focus() {
  local cur prev commands statuses
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  commands="board new show activate park kill done edit intent wip list tui init setup completions version help"
  statuses="active backlog done parked killed"

  case "$prev" in
    focus)
      COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
      return 0
      ;;
    list)
      COMPREPLY=( $(compgen -W "$statuses" -- "$cur") )
      return 0
      ;;
    show|activate|park|kill|done|edit)
      _focus_complete_cards "$cur" "$prev"
      return 0
      ;;
    --project|--priority)
      return 0
      ;;
  esac

  if [[ "$cur" == -* ]]; then
    COMPREPLY=( $(compgen -W "--force --quiet --no-color --project --priority" -- "$cur") )
    return 0
  fi
}

complete -F _focus focus
BASH_COMPLETION
      ;;
    zsh)
      cat << 'ZSH_COMPLETION'
#compdef focus

_focus() {
  local -a commands statuses
  commands=(
    'board:Show the focus board (active + backlog)'
    'new:Create a new backlog card'
    'show:Show a structured card view'
    'activate:Move card to active'
    'park:Move card to parked'
    'kill:Move card to killed'
    'done:Move card to done'
    'edit:Open card in $EDITOR'
    'intent:Set or show session intent'
    'wip:Show WIP status'
    'list:List cards'
    'tui:Interactive terminal UI'
    'init:Create a new kanban board'
    'setup:Point focus at an existing kanban directory'
    'completions:Print shell completions'
    'version:Show version'
    'help:Show help'
  )
  statuses=('active' 'backlog' 'done' 'parked' 'killed')

  _arguments -C \
    '--force[Bypass WIP limit and contract checks]' \
    '--quiet[Suppress non-essential output]' \
    '--no-color[Disable color output]' \
    '--project[Filter by project]:project:' \
    '--priority[Filter by priority]:priority:(p0 p1 p2 p3)' \
    '1:command:->cmd' \
    '2:argument:->arg'

  case $state in
    cmd)
      _describe 'command' commands
      ;;
    arg)
      case ${words[2]} in
        list)
          _describe 'status' statuses
          ;;
        show|activate|park|kill|done|edit)
          local kanban_dir="${FOCUS_KANBAN_DIR:-}"
          if [[ -z "$kanban_dir" ]] && [[ -f "${FOCUS_HOME:-$HOME/.focus}/config" ]]; then
            kanban_dir=$(sed -n 's/^kanban_dir:[[:space:]]*//p' "${FOCUS_HOME:-$HOME/.focus}/config" | head -1)
          fi
          kanban_dir="${kanban_dir:-${FOCUS_HOME:-$HOME/.focus}/kanban}"
          if [[ -n "$kanban_dir" ]] && [[ -d "$kanban_dir" ]]; then
            local -a cards
            local cmd=${words[2]}
            local f id title project status priority
            for f in "$kanban_dir"/*.md(N); do
              id=$(sed -n '/^---$/,/^---$/p' "$f" | grep '^id:' | head -1 | sed 's/^id:[[:space:]]*//')
              [[ -n "$id" ]] || continue
              status=$(sed -n '/^---$/,/^---$/p' "$f" | grep '^status:' | head -1 | sed 's/^status:[[:space:]]*//')
              case "$cmd" in
                activate) [[ "$status" == "backlog" ]] || continue ;;
                park)     [[ "$status" == "active" ]] || continue ;;
                done)     [[ "$status" == "active" ]] || continue ;;
                kill)     [[ "$status" == "backlog" || "$status" == "active" || "$status" == "parked" ]] || continue ;;
                show|edit) ;;
              esac
              title=$(sed -n '/^---$/,/^---$/p' "$f" | grep '^title:' | head -1 | sed 's/^title:[[:space:]]*//')
              project=$(sed -n '/^---$/,/^---$/p' "$f" | grep '^project:' | head -1 | sed 's/^project:[[:space:]]*//')
              priority=$(sed -n '/^---$/,/^---$/p' "$f" | grep '^priority:' | head -1 | sed 's/^priority:[[:space:]]*//')
              cards+=("${id}:${title} [${project:-none}] ${status} ${priority}")
            done
            _describe 'card' cards
          fi
          ;;
      esac
      ;;
  esac
}

_focus "$@"
ZSH_COMPLETION
      ;;
    *)
      echo "error: unsupported shell: $shell (try bash or zsh)" >&2
      return 1
      ;;
  esac
}

_focus_cmd_version() {
  echo "focus $FOCUS_VERSION"
}

_focus_cmd_help() {
  cat << 'EOF'
focus — kanban card manager

Commands:
  board                    Show the focus board (active + backlog)
  new "title" [project]    Create a new backlog card
  show <id|slug>           Show a structured card view
  activate <id|slug>       Move card to active (checks WIP limit)
  park <id|slug>           Move card to parked
  kill <id|slug>           Move card to killed
  done <id|slug>           Move card to done (checks contract)
  edit <id|slug>           Open card in $EDITOR
  intent [message]         Set or show session intent
  wip                      Show WIP status
  list [status]            List cards (optionally filter by status)
  init [dir]               Create a new kanban board (default: ~/.focus/kanban)
  setup <kanban-dir>       Point focus at an existing kanban directory
  tui                      Interactive terminal UI
  completions [bash|zsh]   Print shell completions (eval in .bashrc/.zshrc)
  version                  Show version
  help                     Show this help

Flags:
  --force    Bypass WIP limit and contract checks
  --quiet    Suppress non-essential output
  --project  Filter board/list output by project
  --priority Filter board/list output by priority (p0-p3)
  --no-color Disable color output (or set NO_COLOR)

Statuses: backlog, active, done, parked, killed

Numeric IDs are the primary task reference.
Slugs still map to filenames and continue to work.

Configuration (~/.focus/config):
  kanban_dir    Card directory (default: ~/.focus/kanban)
  wip_limit     Max active cards (default: 3)

Environment overrides:
  FOCUS_HOME        Base directory (default: ~/.focus)
  FOCUS_KANBAN_DIR  Card directory
  FOCUS_WIP_LIMIT   Max active cards
EOF
}

# ── TUI ──────────────────────────────────────────────────────

_focus_tui_statuses=(active backlog done parked killed)

_focus_tui_cleanup() {
  # Restore terminal — order matters: stty first, then screen buffer
  [[ -n "${_tui_saved_stty:-}" ]] && stty "$_tui_saved_stty" 2>/dev/null || stty sane 2>/dev/null || true
  printf '\033[0m'
  tput cnorm 2>/dev/null || true
  tput rmcup 2>/dev/null || true
  printf '\n'
}

_focus_tui_color() {
  local code="$1" text="$2"
  if [[ -n "${NO_COLOR:-}" ]]; then
    printf '%s' "$text"
  else
    printf '\033[%sm%s\033[0m' "$code" "$text"
  fi
}

_focus_tui_load_cards() {
  local status="${_focus_tui_statuses[$_tui_tab]}"
  _tui_cards=()
  _tui_card_ids=()
  _tui_card_titles=()
  _tui_card_projects=()
  _tui_card_priorities=()
  _tui_card_statuses=()
  _tui_card_files=()

  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    local id title project priority
    id="$(_focus_read_field "$f" "id")"
    title="$(_focus_read_field "$f" "title")"
    project="$(_focus_read_field "$f" "project")"
    priority="$(_focus_read_field "$f" "priority")"

    # Apply search filter
    if [[ -n "$_tui_search" ]]; then
      local lower_title lower_project lower_search
      lower_title="$(echo "$title" | tr '[:upper:]' '[:lower:]')"
      lower_project="$(echo "$project" | tr '[:upper:]' '[:lower:]')"
      lower_search="$(echo "$_tui_search" | tr '[:upper:]' '[:lower:]')"
      if [[ "$lower_title" != *"$lower_search"* ]] && [[ "$lower_project" != *"$lower_search"* ]]; then
        continue
      fi
    fi

    _tui_cards+=("$id")
    _tui_card_ids+=("$id")
    _tui_card_titles+=("$title")
    _tui_card_projects+=("$project")
    _tui_card_priorities+=("$priority")
    _tui_card_statuses+=("$status")
    _tui_card_files+=("$f")
  done < <(_focus_sorted_files_for_status "$status")
}

_focus_tui_draw_header() {
  local cols="$1"
  local active_count
  active_count="$(_focus_count_active)"
  local wip_text="WIP: ${active_count}/${FOCUS_WIP_LIMIT}"
  local title="Focus Board"
  local bar
  local right_pad=$(( cols - ${#title} - ${#wip_text} - 6 ))
  (( right_pad < 1 )) && right_pad=1

  tput cup 0 0
  _focus_tui_color '1;7' " ${title}"
  printf '%*s' "$right_pad" ''
  if (( active_count > FOCUS_WIP_LIMIT )); then
    _focus_tui_color '1;7;31' "${wip_text} "
  elif (( active_count == FOCUS_WIP_LIMIT )); then
    _focus_tui_color '1;7;33' "${wip_text} "
  else
    _focus_tui_color '1;7' "${wip_text} "
  fi
  printf '\033[0m'
}

_focus_tui_draw_tabs() {
  local cols="$1"
  tput cup 2 1
  local i
  for i in "${!_focus_tui_statuses[@]}"; do
    local label
    label="$(echo "${_focus_tui_statuses[$i]}" | tr '[:lower:]' '[:upper:]')"
    if (( i == _tui_tab )); then
      _focus_tui_color '1;4' " ${label} "
    else
      case "${_focus_tui_statuses[$i]}" in
        active)  _focus_tui_color '32' " ${label} " ;;
        backlog) _focus_tui_color '36' " ${label} " ;;
        done)    _focus_tui_color '90' " ${label} " ;;
        parked)  _focus_tui_color '33' " ${label} " ;;
        killed)  _focus_tui_color '31' " ${label} " ;;
      esac
    fi
    printf ' '
  done

  # Scroll indicator (right-aligned)
  local count=${#_tui_cards[@]}
  if (( count > 0 )); then
    local first=$(( _tui_scroll + 1 ))
    local last=$(( _tui_scroll + _tui_list_height ))
    (( last > count )) && last=$count
    local indicator="[${first}-${last} of ${count}]"
    local ind_col=$(( cols - ${#indicator} - 1 ))
    (( ind_col > 0 )) && tput cup 2 "$ind_col" && _focus_tui_color '90' "$indicator"
  else
    tput el
  fi
}

_focus_tui_draw_card_list() {
  local cols="$1" list_start="$2" list_height="$3"
  local count=${#_tui_cards[@]}

  # Empty state
  if (( count == 0 )); then
    local r
    for (( r = 0; r < list_height; r++ )); do
      tput cup $(( list_start + r )) 0
      tput el
    done
    local msg='(no cards)'
    local msg_col=$(( (cols - ${#msg}) / 2 ))
    (( msg_col < 0 )) && msg_col=0
    tput cup $(( list_start + list_height / 2 )) "$msg_col"
    _focus_tui_color '90' "$msg"
    return
  fi

  # Adjust scroll offset
  if (( _tui_cursor < _tui_scroll )); then
    _tui_scroll=$_tui_cursor
  fi
  if (( _tui_cursor >= _tui_scroll + list_height )); then
    _tui_scroll=$(( _tui_cursor - list_height + 1 ))
  fi

  local row
  for (( row = 0; row < list_height; row++ )); do
    local idx=$(( _tui_scroll + row ))
    tput cup $(( list_start + row )) 0
    tput el

    if (( idx < count )); then
      local id="${_tui_card_ids[$idx]}"
      local title="${_tui_card_titles[$idx]}"
      local project="${_tui_card_projects[$idx]}"
      local priority="${_tui_card_priorities[$idx]}"

      # Truncate to fit
      local id_w=5 pri_w=4 proj_w=14 pad=6
      local title_max=$(( cols - id_w - pri_w - proj_w - pad - 3 ))
      (( title_max < 10 )) && title_max=10
      local display_title
      display_title="$(_focus_truncate "$title" $title_max)"
      local display_project
      display_project="$(_focus_truncate "$project" $proj_w)"

      local cursor_char=' '
      if (( idx == _tui_cursor )); then
        cursor_char='>'
      fi

      if (( idx == _tui_cursor )) && [[ -z "${NO_COLOR:-}" ]]; then
        printf '\033[7m'
      fi

      printf ' %s ' "$cursor_char"
      printf '#%-4s ' "$id"
      case "$priority" in
        p0) _focus_tui_color '31;1' "$priority" ;;
        p1) _focus_tui_color '33;1' "$priority" ;;
        p2) _focus_tui_color '36' "$priority" ;;
        p3) _focus_tui_color '90' "$priority" ;;
        *)  printf '%s' "$priority" ;;
      esac
      printf '  %-*s  ' "$title_max" "$display_title"
      if [[ -n "${NO_COLOR:-}" ]]; then
        printf '%s' "$display_project"
      else
        _focus_tui_color '90' "$display_project"
      fi

      if (( idx == _tui_cursor )) && [[ -z "${NO_COLOR:-}" ]]; then
        printf '\033[0m'
      fi
    fi
  done
}

_focus_tui_draw_detail() {
  local cols="$1" detail_start="$2" detail_height="$3"
  local count=${#_tui_cards[@]}

  # Draw separator with status label
  tput cup "$detail_start" 0
  local status_label
  status_label="$(echo "${_focus_tui_statuses[$_tui_tab]}" | tr '[:lower:]' '[:upper:]')"
  local sep_label="── ${status_label} (${count}) "
  local sep_rest
  local sep_rest_len=$(( cols - ${#sep_label} ))
  (( sep_rest_len < 0 )) && sep_rest_len=0
  sep_rest=$(printf '%*s' "$sep_rest_len" '' | tr ' ' '─')
  _focus_tui_color '90' "${sep_label}${sep_rest}"

  local content_start=$(( detail_start + 1 ))
  local content_height=$(( detail_height - 1 ))

  if (( count == 0 || _tui_cursor >= count )); then
    tput cup "$content_start" 1
    _focus_tui_color '90' '(no card selected)'
    local r
    for (( r = 1; r < content_height; r++ )); do
      tput cup $(( content_start + r )) 0
      tput el
    done
    return
  fi

  local idx=$_tui_cursor
  local file="${_tui_card_files[$idx]}"
  local title="${_tui_card_titles[$idx]}"
  local project="${_tui_card_projects[$idx]}"
  local priority="${_tui_card_priorities[$idx]}"
  local status="${_tui_card_statuses[$idx]}"
  local updated
  updated="$(_focus_read_field "$file" "updated")"

  # Line 1: Title
  tput cup "$content_start" 1
  tput el
  printf 'Title:    '
  _focus_tui_color '1' "$(_focus_truncate "$title" $(( cols - 12 )))"

  # Line 2: Project
  tput cup $(( content_start + 1 )) 1
  tput el
  if [[ -n "$project" ]]; then
    printf 'Project:  %s' "$project"
  else
    printf 'Project:  '
    _focus_tui_color '90' '(none)'
  fi

  # Line 3: Priority / Status / Updated
  tput cup $(( content_start + 2 )) 1
  tput el
  printf 'Priority: '
  case "$priority" in
    p0) _focus_tui_color '31;1' "$priority" ;;
    p1) _focus_tui_color '33;1' "$priority" ;;
    p2) _focus_tui_color '36' "$priority" ;;
    p3) _focus_tui_color '90' "$priority" ;;
    *)  printf '%s' "$priority" ;;
  esac
  printf '    Status: '
  case "$status" in
    active)  _focus_tui_color '32;1' "$status" ;;
    backlog) _focus_tui_color '36' "$status" ;;
    done)    _focus_tui_color '90' "$status" ;;
    parked)  _focus_tui_color '33' "$status" ;;
    killed)  _focus_tui_color '31' "$status" ;;
  esac
  printf '    Updated: %s' "$updated"

  # Remaining lines: body preview
  local body_start=$(( content_start + 4 ))
  local body_lines=$(( content_height - 4 ))
  (( body_lines < 0 )) && body_lines=0

  # Blank line
  tput cup $(( content_start + 3 )) 0
  tput el

  local body_text
  body_text="$(_focus_read_body "$file")"
  local line_num=0
  while IFS= read -r line && (( line_num < body_lines )); do
    tput cup $(( body_start + line_num )) 1
    tput el
    printf '%s' "${line:0:$((cols - 2))}"
    (( ++line_num ))
  done <<< "$body_text"

  # Clear remaining lines
  while (( line_num < body_lines )); do
    tput cup $(( body_start + line_num )) 0
    tput el
    (( ++line_num ))
  done
}

_focus_tui_draw_status_bar() {
  local cols="$1" rows="$2"
  tput cup $(( rows - 2 )) 0
  local sep
  sep=$(printf '%*s' "$cols" '' | tr ' ' '═')
  _focus_tui_color '90' "$sep"

  tput cup $(( rows - 1 )) 0
  tput el
  if [[ -n "$_tui_search" ]]; then
    _focus_tui_color '33' " /${_tui_search}"
    _focus_tui_color '90' '  Esc:clear'
  elif $_tui_search_mode; then
    _focus_tui_color '33' ' /'
    printf '%s' "$_tui_search_buf"
    _focus_tui_color '90' '  Enter:done  Esc:clear'
  else
    _focus_tui_color '90' ' j/k:move  h/l:tab  a:act  p:park  d:done  K:kill  e:edit  n:new  r:reload  /:find  q:quit'
  fi
}

_focus_tui_draw_message() {
  local cols="$1" rows="$2"
  if [[ -n "$_tui_message" ]]; then
    tput cup $(( rows - 1 )) 0
    tput el
    _focus_tui_color '32;1' " ${_tui_message}"
  fi
}

_focus_tui_full_draw() {
  local cols rows
  cols=$(tput cols)
  rows=$(tput lines)

  (( cols < 40 )) && cols=40
  (( rows < 10 )) && rows=10

  # Layout: header=1, blank=1, tabs=1, blank=1, card_list, separator=1, detail, separator=1, statusbar=1
  local list_start=4
  local footer_lines=2  # separator + status bar
  local detail_height=$(( (rows - list_start - footer_lines) * 50 / 100 ))
  (( detail_height < 5 )) && detail_height=5
  local list_height=$(( rows - list_start - detail_height - footer_lines ))
  (( list_height < 3 )) && list_height=3
  _tui_list_height=$list_height
  local detail_start=$(( list_start + list_height ))

  tput clear
  _focus_tui_draw_header "$cols"
  _focus_tui_draw_tabs "$cols"
  _focus_tui_draw_card_list "$cols" "$list_start" "$list_height"
  _focus_tui_draw_detail "$cols" "$detail_start" "$detail_height"
  _focus_tui_draw_status_bar "$cols" "$rows"
  _focus_tui_draw_message "$cols" "$rows"
}

_focus_tui_partial_draw() {
  local cols rows
  cols=$(tput cols)
  rows=$(tput lines)

  (( cols < 40 )) && cols=40
  (( rows < 10 )) && rows=10

  local list_start=4
  local footer_lines=2
  local detail_height=$(( (rows - list_start - footer_lines) * 50 / 100 ))
  (( detail_height < 5 )) && detail_height=5
  local list_height=$(( rows - list_start - detail_height - footer_lines ))
  (( list_height < 3 )) && list_height=3
  _tui_list_height=$list_height
  local detail_start=$(( list_start + list_height ))

  _focus_tui_draw_tabs "$cols"
  _focus_tui_draw_card_list "$cols" "$list_start" "$list_height"
  _focus_tui_draw_detail "$cols" "$detail_start" "$detail_height"
  _focus_tui_draw_status_bar "$cols" "$rows"
  _focus_tui_draw_message "$cols" "$rows"
}

_focus_tui_read_key() {
  local c
  IFS= read -rsn1 c 2>/dev/null || return 1

  if [[ "$c" == $'\e' ]]; then
    local seq
    IFS= read -rsn1 -t 0.05 seq 2>/dev/null || { echo 'escape'; return; }
    if [[ "$seq" == '[' ]]; then
      IFS= read -rsn1 -t 0.05 seq 2>/dev/null || { echo 'escape'; return; }
      case "$seq" in
        A) echo 'up' ;;
        B) echo 'down' ;;
        C) echo 'right' ;;
        D) echo 'left' ;;
        *) echo 'unknown' ;;
      esac
    else
      echo 'escape'
    fi
  elif [[ "$c" == '' ]]; then
    echo 'enter'
  elif [[ "$c" == $'\t' ]]; then
    echo 'tab'
  elif [[ "$c" == $'\x03' ]]; then
    echo 'ctrl-c'
  elif [[ "$c" == $'\x04' ]]; then
    echo 'ctrl-d'
  elif [[ "$c" == $'\x15' ]]; then
    echo 'ctrl-u'
  elif [[ "$c" == $'\x7f' ]] || [[ "$c" == $'\b' ]]; then
    echo 'backspace'
  else
    printf '%s' "$c"
  fi
}

_focus_cmd_tui() {
  _focus_require_kanban_dir

  # Check terminal capabilities
  if ! command -v tput &>/dev/null; then
    echo "error: tput not found (required for TUI)" >&2
    return 1
  fi
  if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
    echo "error: TUI requires an interactive terminal" >&2
    return 1
  fi

  # Minimum terminal size check
  local _tui_cols _tui_rows
  _tui_cols=$(tput cols)
  _tui_rows=$(tput lines)
  if (( _tui_cols < 80 || _tui_rows < 24 )); then
    echo "error: TUI requires at least 80x24 terminal (current: ${_tui_cols}x${_tui_rows})" >&2
    return 1
  fi

  # State
  local _tui_tab=0
  local _tui_cursor=0
  local _tui_scroll=0
  local _tui_list_height=0
  local _tui_search=''
  local _tui_search_mode=false
  local _tui_search_buf=''
  local _tui_message=''
  local _tui_message_ttl=0
  local _tui_running=true

  # Save terminal state
  local _tui_saved_stty
  _tui_saved_stty="$(stty -g)"
  trap '_focus_tui_cleanup' EXIT INT TERM
  trap '_focus_tui_full_draw' WINCH

  tput smcup       # alternate screen
  tput civis       # hide cursor
  stty raw -echo   # raw mode

  # Card data arrays (populated by _focus_tui_load_cards)
  local _tui_cards=() _tui_card_ids=() _tui_card_titles=()
  local _tui_card_projects=() _tui_card_priorities=()
  local _tui_card_statuses=() _tui_card_files=()

  _focus_tui_load_cards
  _focus_tui_full_draw

  while $_tui_running; do
    if (( _tui_message_ttl > 0 )); then
      (( _tui_message_ttl-- ))
      if (( _tui_message_ttl == 0 )); then
        _tui_message=''
      fi
    fi
    local key
    key="$(_focus_tui_read_key)" || continue

    if $_tui_search_mode; then
      case "$key" in
        enter)
          # Commit search and exit search mode
          _tui_search_mode=false
          _focus_tui_full_draw
          ;;
        escape)
          # Cancel search, clear filter
          _tui_search_mode=false
          _tui_search_buf=''
          _tui_search=''
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
          ;;
        backspace)
          if [[ -n "$_tui_search_buf" ]]; then
            _tui_search_buf="${_tui_search_buf%?}"
          fi
          _tui_search="$_tui_search_buf"
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
          ;;
        *)
          if [[ ${#key} -eq 1 ]] && [[ "$key" =~ [[:print:]] ]]; then
            _tui_search_buf+="$key"
          fi
          _tui_search="$_tui_search_buf"
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
          ;;
      esac
      continue
    fi

    case "$key" in
      q|ctrl-c)
        _tui_running=false
        ;;
      up|k)
        if (( _tui_cursor > 0 )); then
          (( _tui_cursor-- ))
          _focus_tui_partial_draw
        fi
        ;;
      down|j)
        if (( _tui_cursor < ${#_tui_cards[@]} - 1 )); then
          (( ++_tui_cursor ))
          _focus_tui_partial_draw
        fi
        ;;
      G)
        # Jump to bottom
        if (( ${#_tui_cards[@]} > 0 )); then
          _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
          _focus_tui_partial_draw
        fi
        ;;
      g)
        # gg = jump to top
        local g2
        IFS= read -rsn1 -t 0.3 g2 2>/dev/null || g2=''
        if [[ "$g2" == 'g' ]]; then
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_partial_draw
        fi
        ;;
      ctrl-d)
        # Half-page down
        if (( ${#_tui_cards[@]} > 0 )); then
          local half=$(( _tui_list_height / 2 ))
          (( half < 1 )) && half=1
          _tui_cursor=$(( _tui_cursor + half ))
          local max=$(( ${#_tui_cards[@]} - 1 ))
          (( _tui_cursor > max )) && _tui_cursor=$max
          _focus_tui_partial_draw
        fi
        ;;
      ctrl-u)
        # Half-page up
        if (( ${#_tui_cards[@]} > 0 )); then
          local half=$(( _tui_list_height / 2 ))
          (( half < 1 )) && half=1
          _tui_cursor=$(( _tui_cursor - half ))
          (( _tui_cursor < 0 )) && _tui_cursor=0
          _focus_tui_partial_draw
        fi
        ;;
      left|h)
        if (( _tui_tab > 0 )); then
          (( _tui_tab-- ))
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
        fi
        ;;
      right|l)
        if (( _tui_tab < ${#_focus_tui_statuses[@]} - 1 )); then
          (( ++_tui_tab ))
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
        fi
        ;;
      tab)
        _tui_tab=$(( (_tui_tab + 1) % ${#_focus_tui_statuses[@]} ))
        _tui_cursor=0
        _tui_scroll=0
        _focus_tui_load_cards
        _focus_tui_full_draw
        ;;
      a)
        # Activate selected card
        if (( ${#_tui_cards[@]} > 0 && _tui_cursor < ${#_tui_cards[@]} )); then
          local card_id="${_tui_card_ids[$_tui_cursor]}"
          local result
          result="$(FORCE=$FORCE _focus_cmd_activate "$card_id" 2>&1)" && \
            _tui_message="$result" || _tui_message="$result"
          _tui_message_ttl=3
          _focus_tui_load_cards
          (( _tui_cursor >= ${#_tui_cards[@]} && ${#_tui_cards[@]} > 0 )) && _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
          _focus_tui_full_draw
        fi
        ;;
      p)
        # Park selected card
        if (( ${#_tui_cards[@]} > 0 && _tui_cursor < ${#_tui_cards[@]} )); then
          local card_id="${_tui_card_ids[$_tui_cursor]}"
          local result
          result="$(QUIET=true _focus_cmd_park "$card_id" 2>&1)" && \
            _tui_message="Parked: ${card_id}" || _tui_message="$result"
          _tui_message_ttl=3
          _focus_tui_load_cards
          (( _tui_cursor >= ${#_tui_cards[@]} && ${#_tui_cards[@]} > 0 )) && _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
          _focus_tui_full_draw
        fi
        ;;
      d)
        # Done selected card (--force to skip contract prompts in TUI)
        if (( ${#_tui_cards[@]} > 0 && _tui_cursor < ${#_tui_cards[@]} )); then
          local card_id="${_tui_card_ids[$_tui_cursor]}"
          local path
          path="$(_focus_card_path "$card_id")" || continue
          _focus_set_field "$path" "status" "done"
          _focus_set_field "$path" "updated" "$(_focus_today)"
          _tui_message="Done: ${card_id}"
          _tui_message_ttl=3
          _focus_tui_load_cards
          (( _tui_cursor >= ${#_tui_cards[@]} && ${#_tui_cards[@]} > 0 )) && _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
          _focus_tui_full_draw
        fi
        ;;
      K)
        # Kill selected card (requires confirmation)
        if (( ${#_tui_cards[@]} > 0 && _tui_cursor < ${#_tui_cards[@]} )); then
          local card_id="${_tui_card_ids[$_tui_cursor]}"
          local card_title="${_tui_card_titles[$_tui_cursor]}"
          local cols rows
          cols=$(tput cols)
          rows=$(tput lines)
          tput cup $(( rows - 1 )) 0
          tput el
          _focus_tui_color '31;1' " Kill #${card_id} ${card_title}? "
          _focus_tui_color '90' 'y:confirm  any:cancel'
          local confirm_key
          confirm_key="$(_focus_tui_read_key)" || confirm_key=''
          if [[ "$confirm_key" == 'y' ]]; then
            local result
            result="$(QUIET=true _focus_cmd_kill "$card_id" 2>&1)" && \
              _tui_message="Killed: ${card_id}" || _tui_message="$result"
            _tui_message_ttl=3
            _focus_tui_load_cards
            (( _tui_cursor >= ${#_tui_cards[@]} && ${#_tui_cards[@]} > 0 )) && _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
          else
            _tui_message='Kill cancelled'
            _tui_message_ttl=2
          fi
          _focus_tui_full_draw
        fi
        ;;
      e)
        # Edit in $EDITOR
        if (( ${#_tui_cards[@]} > 0 && _tui_cursor < ${#_tui_cards[@]} )); then
          local file="${_tui_card_files[$_tui_cursor]}"
          local edit_id="${_tui_card_ids[$_tui_cursor]}"
          # Restore terminal for editor
          tput rmcup
          stty "$_tui_saved_stty"
          tput cnorm
          "${EDITOR:-vi}" "$file"
          _focus_set_field "$file" "updated" "$(_focus_today)"
          # Re-enter TUI
          stty raw -echo
          tput smcup
          tput civis
          _focus_tui_load_cards
          # Restore cursor to the edited card
          local _ei
          _tui_cursor=0
          for _ei in "${!_tui_card_ids[@]}"; do
            if [[ "${_tui_card_ids[$_ei]}" == "$edit_id" ]]; then
              _tui_cursor=$_ei
              break
            fi
          done
          _focus_tui_full_draw
        fi
        ;;
      n)
        # Inline new card creation u2014 raw-mode prompts with Esc-to-cancel
        local _new_buf='' _new_phase='title' _new_title='' _new_cancelled=false
        local cols rows
        cols=$(tput cols)
        rows=$(tput lines)
        tput cup $(( rows - 1 )) 0
        tput el
        _focus_tui_color '33' ' New title: '
        _focus_tui_color '90' ' Esc:cancel'
        tput cnorm

        while true; do
          local nk
          nk="$(_focus_tui_read_key)" || continue
          case "$nk" in
            escape)
              _new_cancelled=true
              break
              ;;
            enter)
              if [[ "$_new_phase" == 'title' ]]; then
                if [[ -z "$_new_buf" ]]; then
                  _new_cancelled=true
                  break
                fi
                _new_title="$_new_buf"
                _new_buf=''
                _new_phase='project'
                tput cup $(( rows - 1 )) 0
                tput el
                _focus_tui_color '33' ' Project (optional): '
                _focus_tui_color '90' ' Esc:cancel  Enter:skip'
              else
                break
              fi
              ;;
            backspace)
              if [[ -n "$_new_buf" ]]; then
                _new_buf="${_new_buf%?}"
                tput cup $(( rows - 1 )) 0
                tput el
                if [[ "$_new_phase" == 'title' ]]; then
                  _focus_tui_color '33' ' New title: '
                else
                  _focus_tui_color '33' ' Project (optional): '
                fi
                printf '%s' "$_new_buf"
                _focus_tui_color '90' '  Esc:cancel'
              fi
              ;;
            *)
              if [[ ${#nk} -eq 1 ]] && [[ "$nk" =~ [[:print:]] ]]; then
                _new_buf+="$nk"
                tput cup $(( rows - 1 )) 0
                tput el
                if [[ "$_new_phase" == 'title' ]]; then
                  _focus_tui_color '33' ' New title: '
                else
                  _focus_tui_color '33' ' Project (optional): '
                fi
                printf '%s' "$_new_buf"
                _focus_tui_color '90' '  Esc:cancel'
              fi
              ;;
          esac
        done

        tput civis
        if ! $_new_cancelled && [[ -n "$_new_title" ]]; then
          local result
          result="$(QUIET=true _focus_cmd_new "$_new_title" "$_new_buf" 2>&1)" && \
            _tui_message="Created: ${_new_title}" || _tui_message="$result"
          _tui_message_ttl=3
          _focus_tui_load_cards
        fi
        _focus_tui_full_draw
        ;;
      /)
        _tui_search_mode=true
        _tui_search_buf=''
        _focus_tui_full_draw
        ;;
      r)
        # Reload all data and re-render
        _focus_tui_load_cards
        (( _tui_cursor >= ${#_tui_cards[@]} && ${#_tui_cards[@]} > 0 )) && _tui_cursor=$(( ${#_tui_cards[@]} - 1 ))
        _tui_message='Reloaded'
        _tui_message_ttl=2
        _focus_tui_full_draw
        ;;
      escape)
        if [[ -n "$_tui_search" ]]; then
          _tui_search=''
          _tui_search_buf=''
          _tui_cursor=0
          _tui_scroll=0
          _focus_tui_load_cards
          _focus_tui_full_draw
        fi
        ;;
    esac
  done

  trap - EXIT INT TERM WINCH
  _focus_tui_cleanup
}

# ── Main Dispatcher ──────────────────────────────────────────

main() {
  local args=()
  local i=1
  while [[ $i -le $# ]]; do
    local arg="${!i}"
    case "$arg" in
      --force) FORCE=true ;;
      --quiet) QUIET=true ;;
      --no-color) COLOR_ENABLED=false ;;
      --project)
        ((i++))
        [[ $i -le $# ]] || { echo "error: --project requires a value" >&2; return 1; }
        FILTER_PROJECT="${!i}"
        ;;
      --priority)
        ((i++))
        [[ $i -le $# ]] || { echo "error: --priority requires a value" >&2; return 1; }
        FILTER_PRIORITY="${!i}"
        ;;
      *)
        args+=("$arg")
        ;;
    esac
    ((i++))
  done

  local cmd="${args[0]:-board}"

  case "$cmd" in
    board)    _focus_cmd_board ;;
    new)      _focus_cmd_new "${args[1]:-}" "${args[2]:-}" ;;
    show)     _focus_cmd_show "${args[1]:-}" ;;
    activate) _focus_cmd_activate "${args[1]:-}" ;;
    park)     _focus_cmd_park "${args[1]:-}" ;;
    kill)     _focus_cmd_kill "${args[1]:-}" ;;
    done)     _focus_cmd_done "${args[1]:-}" ;;
    edit)     _focus_cmd_edit "${args[1]:-}" ;;
    intent)   _focus_cmd_intent "${args[1]:-}" ;;
    wip)      _focus_cmd_wip ;;
    list)     _focus_cmd_list "${args[1]:-}" ;;
    init)     _focus_cmd_init "${args[1]:-}" ;;
    setup)    _focus_cmd_setup "${args[1]:-}" ;;
    tui)     _focus_cmd_tui ;;
    completions) _focus_cmd_completions "${args[1]:-}" ;;
    version|-v|--version) _focus_cmd_version ;;
    help|-h|--help) _focus_cmd_help ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo "Run 'focus help' for usage." >&2
      return 1
      ;;
  esac
}

main "$@"
